{
  "description": "Bundles Forge bootstrap: injects skill routing context on session start",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.py\"",
            "timeout": 10,
            "async": false
          }
        ]
      }
    ]
  }
}
