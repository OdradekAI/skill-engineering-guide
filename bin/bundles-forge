#!/bin/sh
''':'
# --- Shell preamble: find a working Python, then re-exec this file through it ---
set -e
find_python() {
    for candidate in python3 python; do
        cmd_path=$(command -v "$candidate" 2>/dev/null) || continue
        if output=$("$candidate" --version 2>&1) && \
           printf '%s' "$output" | grep -q '^Python'; then
            printf '%s' "$candidate"
            return 0
        fi
        printf 'bundles-forge: skipped %s (%s) — not a working interpreter\n' \
            "$candidate" "$cmd_path" >&2
    done
    return 1
}
PYTHON=$(find_python) || {
    printf 'bundles-forge: error: Python 3.9+ required but not found\n' >&2
    printf '  Tried: python3, python\n' >&2
    printf '  Install: https://www.python.org/downloads/\n' >&2
    exit 1
}
exec "$PYTHON" "$0" "$@"
'''
"""bundles-forge CLI - unified cross-skill script dispatcher.

Routes subcommands to the correct script inside the plugin.
Uses subprocess.call to preserve __file__ semantics, exit codes,
and stdout/stderr pass-through.

Shell/Python polyglot: when executed by a shell (Git Bash, bash, sh),
the ''':', block probes python3/python via --version before exec,
skipping Windows Store stubs. When loaded by Python directly
(e.g. via bundles-forge.cmd), the triple-quoted string is a no-op.

Usage:
    bundles-forge <command> [args...]
    bundles-forge -h | --help
"""
import subprocess
import sys
from pathlib import Path

if sys.version_info < (3, 9):
    sys.exit("bundles-forge requires Python 3.9+")

_ROOT = Path(__file__).resolve().parent.parent

COMMANDS = {
    "audit-skill":    _ROOT / "skills" / "auditing" / "scripts" / "audit_skill.py",
    "audit-security": _ROOT / "skills" / "auditing" / "scripts" / "audit_security.py",
    "audit-docs":     _ROOT / "skills" / "auditing" / "scripts" / "audit_docs.py",
    "audit-plugin":   _ROOT / "skills" / "auditing" / "scripts" / "audit_plugin.py",
    "audit-workflow": _ROOT / "skills" / "auditing" / "scripts" / "audit_workflow.py",
    "checklists":     _ROOT / "skills" / "auditing" / "scripts" / "generate_checklists.py",
    "bump-version":   _ROOT / "skills" / "releasing" / "scripts" / "bump_version.py",
}


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        print("Usage: bundles-forge <command> [args...]")
        print()
        print("Commands:")
        for name in COMMANDS:
            print(f"  {name}")
        sys.exit(0)

    cmd = sys.argv[1]
    args = sys.argv[2:]

    script = COMMANDS.get(cmd)
    if script is None:
        print(f"bundles-forge: unknown command '{cmd}'", file=sys.stderr)
        print(f"Available: {', '.join(COMMANDS)}", file=sys.stderr)
        sys.exit(1)

    if not script.exists():
        print(f"bundles-forge: script not found: {script}", file=sys.stderr)
        sys.exit(1)

    sys.exit(subprocess.call([sys.executable, str(script)] + args))


if __name__ == "__main__":
    main()
